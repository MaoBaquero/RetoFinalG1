# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude .tfvars by default (may contain secrets)
*.tfvars
*.tfvars.json

# Environment tfvars for CI (no secrets in this project)
!code_terraform/envs/
!code_terraform/envs/**/
!code_terraform/envs/**/*.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

.terraform.tfstate.lock.info
.terraformrc
terraform.rc
